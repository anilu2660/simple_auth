# AuthVault — Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
# Get this from: MongoDB Atlas → Your Cluster → Connect → Connect your application
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/authvault?retryWrites=true&w=majority

# JWT Secret — use a long random string in production
JWT_SECRET=authvault_super_secret_jwt_key_change_this_in_production_123!

# Server port
PORT=3000
